{
  "version": 2,
  "public": true,
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/api/inference", "destination": "/api/inference" },
    { "source": "/api/events",    "destination": "/api/events" }
  ],
  "headers": [
    {
      "source": "/api/events",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-transform" },
        { "key": "X-Accel-Buffering", "value": "no" }
      ]
    }
  ]
}
